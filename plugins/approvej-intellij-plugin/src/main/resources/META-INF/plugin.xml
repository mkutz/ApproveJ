<idea-plugin>
  <id>org.approvej</id>
  <name>ApproveJ</name>
  <vendor>ApproveJ</vendor>

  <description><![CDATA[
    Approval testing support for ApproveJ.
    Provides diff viewing and one-click approval of <code>.received</code> files.
  ]]></description>

  <depends>com.intellij.modules.platform</depends>
  <depends>com.intellij.modules.java</depends>

  <extensions defaultExtensionNs="com.intellij">
    <localInspection
        language="UAST"
        groupName="ApproveJ"
        shortName="DanglingApproval"
        displayName="Dangling approval"
        enabledByDefault="true"
        level="WARNING"
        implementationClass="org.approvej.intellij.DanglingApprovalInspection"/>
    <editorNotificationProvider
        implementation="org.approvej.intellij.ReceivedFileEditorNotificationProvider"/>
    <editorNotificationProvider
        implementation="org.approvej.intellij.ApprovedFileEditorNotificationProvider"/>
    <codeInsight.lineMarkerProvider
        language="UAST"
        implementationClass="org.approvej.intellij.ApproveCallLineMarkerProvider"/>
  </extensions>

  <actions>
    <group id="ApproveJ" text="ApproveJ" popup="true">
      <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
      <action id="ApproveJ.CompareReceivedWithApproved"
          class="org.approvej.intellij.CompareReceivedWithApprovedAction"
          text="Compare with Approved"
          description="Open diff viewer comparing received file with approved file"/>
      <action id="ApproveJ.ApproveReceived"
          class="org.approvej.intellij.ApproveReceivedAction"
          text="Approve Received"
          description="Copy received file content to approved file and delete received file"/>
    </group>
  </actions>
</idea-plugin>
