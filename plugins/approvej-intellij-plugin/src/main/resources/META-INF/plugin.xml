<idea-plugin>
  <id>org.approvej</id>
  <name>ApproveJ</name>
  <vendor>ApproveJ</vendor>

  <description><![CDATA[
    Approval testing support for ApproveJ.
    Provides diff viewing, one-click approval, bidirectional navigation between
    test code and approved files, dangling approval detection, and duplicate
    unnamed approval detection.
  ]]></description>

  <depends>com.intellij.modules.platform</depends>
  <depends>com.intellij.modules.java</depends>

  <extensions defaultExtensionNs="com.intellij">
    <dependencySupport kind="java" coordinate="org.approvej:core" displayName="ApproveJ"/>
    <dependencySupport kind="java" coordinate="org.approvej:http" displayName="ApproveJ"/>
    <dependencySupport kind="java" coordinate="org.approvej:http-wiremock" displayName="ApproveJ"/>
    <dependencySupport kind="java" coordinate="org.approvej:image" displayName="ApproveJ"/>
    <dependencySupport kind="java" coordinate="org.approvej:json-jackson" displayName="ApproveJ"/>
    <dependencySupport kind="java" coordinate="org.approvej:json-jackson3" displayName="ApproveJ"/>
    <dependencySupport kind="java" coordinate="org.approvej:yaml-jackson" displayName="ApproveJ"/>
    <dependencySupport kind="java" coordinate="org.approvej:yaml-jackson3" displayName="ApproveJ"/>
    <localInspection
        language="UAST"
        groupName="ApproveJ"
        shortName="DanglingApproval"
        displayName="Dangling approval"
        enabledByDefault="true"
        level="WARNING"
        implementationClass="org.approvej.intellij.DanglingApprovalInspection"/>
    <localInspection
        language="UAST"
        groupName="ApproveJ"
        shortName="DuplicateUnnamedApproval"
        displayName="Duplicate unnamed approval"
        enabledByDefault="true"
        level="WARNING"
        implementationClass="org.approvej.intellij.DuplicateUnnamedApprovalInspection"/>
    <editorNotificationProvider
        implementation="org.approvej.intellij.ReceivedFileEditorNotificationProvider"/>
    <editorNotificationProvider
        implementation="org.approvej.intellij.ApprovedFileEditorNotificationProvider"/>
    <codeInsight.lineMarkerProvider
        language="UAST"
        implementationClass="org.approvej.intellij.ApproveCallLineMarkerProvider"/>
    <diff.DiffTool implementation="org.approvej.intellij.ImageDiffTool"/>
    <diff.DiffExtension
        implementation="org.approvej.intellij.ApproveJDiffExtension"/>
    <renamePsiElementProcessor order="last"
        implementation="org.approvej.intellij.ApproveJRenamePsiElementProcessor"/>
    <refactoring.elementListenerProvider
        implementation="org.approvej.intellij.ApproveJRefactoringListenerProvider"/>
  </extensions>

  <actions>
    <group id="ApproveJ" text="ApproveJ" popup="true">
      <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
      <action id="ApproveJ.CompareReceivedWithApproved"
          class="org.approvej.intellij.CompareReceivedWithApprovedAction"
          text="Compare with Approved"
          description="Open diff viewer comparing received file with approved file"/>
      <action id="ApproveJ.ApproveReceived"
          class="org.approvej.intellij.ApproveReceivedAction"
          text="Approve Received"
          description="Copy received file content to approved file and delete received file"/>
    </group>
  </actions>
</idea-plugin>
